generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Meeting {
  id                 String    @id @default(cuid())
  hostId             String
  defaultLanguage    String
  status             String    @default("ACTIVE")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  hostUserId         String?
  scheduledMeetingId String?   @unique
  admitList          String    @default("[]")
  endedAt            DateTime?
  expiresAt          DateTime?

  hostUser            User?                @relation("HostedMeetings", fields: [hostUserId], references: [id])
  scheduledMeeting    ScheduledMeeting?    @relation("MeetingScheduledMeeting", fields: [scheduledMeetingId], references: [id])
  liveSchedule        ScheduledMeeting?    @relation("ScheduledMeetingLiveMeeting")
  magicLinks          MagicLink[]
  meetingParticipants MeetingParticipant[]
  participantLogs     ParticipantLog[]

  @@index([status])
  @@index([expiresAt])
}

model MeetingParticipant {
  id                String          @id @default(cuid())
  meetingId         String
  userId            String
  role              ParticipantRole @default(PARTICIPANT)
  preferredLanguage String          @default("en")
  joinedAt          DateTime        @default(now())
  leftAt            DateTime?
  isMuted           Boolean         @default(false)
  isOnline          Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  meeting     Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  participant User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

model ParticipantLog {
  id            String   @id @default(cuid())
  meetingId     String
  participantId String
  eventType     String
  metadata      Json?
  createdAt     DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, createdAt])
  @@index([createdAt])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  passwordHash String
  role         UserRole @default(PARTICIPANT)
  createdAt    DateTime @default(now())

  hostedMeetings      Meeting[]            @relation("HostedMeetings")
  magicLinks          MagicLink[]
  scheduledMeetings   ScheduledMeeting[]
  meetingParticipants MeetingParticipant[]
}

model MagicLink {
  id              String    @id @default(cuid())
  token           String    @unique
  meetingId       String
  inviteeEmail    String?
  expiresAt       DateTime
  usedAt          DateTime?
  usedByUserId    String?
  createdAt       DateTime  @default(now())
  createdByUserId String

  meeting   Meeting @relation(fields: [meetingId], references: [id])
  createdBy User    @relation(fields: [createdByUserId], references: [id])

  @@index([expiresAt])
}

model ScheduledMeeting {
  id              String    @id @default(cuid())
  title           String
  scheduledAt     DateTime
  durationMinutes Int       @default(60)
  timezone        String    @default("UTC")
  hostId          String
  meetingId       String?   @unique
  shareToken      String    @unique
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  cancelledAt     DateTime?

  host         User     @relation(fields: [hostId], references: [id])
  scheduledFor Meeting? @relation("MeetingScheduledMeeting")
  meeting      Meeting? @relation("ScheduledMeetingLiveMeeting", fields: [meetingId], references: [id])

  @@index([hostId])
  @@index([scheduledAt])
}

enum UserRole {
  HOST
  PARTICIPANT
}

enum ParticipantRole {
  HOST
  CO_HOST
  PARTICIPANT
}
